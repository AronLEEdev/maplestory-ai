{
  "name": "maplestory.ai",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "bin": {
    "maplestory.ai": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --no-error-on-unmatched-pattern src tests",
    "format": "prettier --write src tests",
    "postinstall": "chmod +x node_modules/node-global-key-listener/bin/MacKeyServer 2>/dev/null; node -e \"const f=require('path').join('node_modules','sudo-prompt','index.js');let s=require('fs').readFileSync(f,'utf8');if(!s.includes('isObject:')){s=s.replace('util: require(\\'util\\')','util: {...require(\\'util\\'), isObject(a){return a!==null&&typeof a===\\'object\\'},isFunction(a){return typeof a===\\'function\\'}}');require('fs').writeFileSync(f,s)}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@nut-tree-fork/nut-js": "^4.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.0",
    "node-global-key-listener": "^0.3.0",
    "node-screenshots": "^0.2.8",
    "onnxruntime-node": "^1.25.1",
    "pino": "^9.0.0",
    "screenshot-desktop": "^1.15.0",
    "sharp": "^0.33.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
